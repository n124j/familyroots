# ============================================================
#  FamilyRoots — GCP Production Environment
#
#  Copy to .env.prod and fill in all values before deploying:
#    cp .env.prod.example .env.prod
#
#  Deploy:
#    docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# ============================================================

# ── Domain ──────────────────────────────────────────────────
# Your domain pointing to this VM's external IP.
# Used for TLS certificate, CORS, OAuth callbacks, email links.
DOMAIN=familyroots.yourdomain.com

# ── Certbot / Let's Encrypt ─────────────────────────────────
CERTBOT_EMAIL=you@example.com

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=familyroots
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_pg_strong_password

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_redis_strong_password

# ── MinIO (S3-compatible storage) ───────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_strong_password
S3_BUCKET=familyroots-media
S3_REGION=us-east-1

# ── JWT ─────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64

# ── Default tenant ──────────────────────────────────────────
# UUID for auto-provisioned OAuth users.  Generate with: uuidgen
DEFAULT_TENANT_ID=
DEFAULT_TENANT_SLUG=familyroots-system

# ── Gmail SMTP ──────────────────────────────────────────────
# Use a Gmail App Password — not your account password.
# Setup: Google Account > Security > App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourdomain.com

# ── Google OAuth ────────────────────────────────────────────
# Google Cloud Console > APIs & Services > Credentials
# Authorized redirect URI:  https://DOMAIN/api/v1/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitHub OAuth (optional) ─────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Web Push / VAPID (optional) ─────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=

# ── Sentry (optional) ──────────────────────────────────────
SENTRY_DSN=
