# ── Application ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=FamilyRoots
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Server ───────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://familyroots:password@localhost:7000/familyroots
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:7001/0
REDIS_POOL_SIZE=20

# ── JWT ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET_KEY=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_REFRESH_TOKEN_REMEMBER_ME_DAYS=90

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:7009","http://localhost:7006"]
CORS_ALLOW_CREDENTIALS=true

# ── AWS S3 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=familyroots-media
S3_PRESIGNED_URL_EXPIRE_SECONDS=900

# ── OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@familyroots.app

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_PER_MINUTE=60

# ── Sentry ───────────────────────────────────────────────────
SENTRY_DSN=
